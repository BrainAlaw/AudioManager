<Application x:Class="AudioManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <FontFamily x:Key="Vm.DisplayFont">pack://application:,,,/font/VeniteAdoremus-rgRBA.ttf#Venite Adoremus</FontFamily>
            <FontFamily x:Key="Vm.DisplayFontStraight">pack://application:,,,/font/VeniteAdoremusStraight-Yzo6v.ttf#Venite Adoremus Straight</FontFamily>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/DarkTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
