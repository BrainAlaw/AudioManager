<UserControl x:Class="AudioManager.Views.ChannelStripView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodels="clr-namespace:AudioManager.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:ChannelStripViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="120">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="InlineRenameTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="22" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Foreground" Value="{StaticResource Vm.TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="FontStyle" Value="Normal" />
            <Setter Property="CaretBrush" Value="{StaticResource Vm.AccentBrush}" />
            <Setter Property="Opacity" Value="1" />
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="1"
                                             To="0.62"
                                             Duration="0:0:0.55" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IconActionButton" TargetType="Button" BasedOn="{StaticResource Vm.SmallButton}">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="ChannelNameButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource Vm.TextBrush}" />
            <Setter Property="Cursor" Value="IBeam" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppMoreToggle" TargetType="ToggleButton" BasedOn="{StaticResource Vm.TextToggle}">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="MinWidth" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Content" Value="+" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Resources>
    <Border Style="{StaticResource Vm.ChannelStrip}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Top Header -->
            <Grid Grid.Row="0" Margin="0,0,0,0">
                <Grid HorizontalAlignment="Center"
                      VerticalAlignment="Top"
                      Margin="0,10,0,0"
                      Height="22">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding SpacedName}"
                               FontSize="15"
                               FontStyle="Normal"
                               FontWeight="Normal"
                               HorizontalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{StaticResource Vm.TextBrush}"
                               Cursor="IBeam"
                               MouseLeftButtonDown="ChannelName_MouseLeftButtonDown">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Setter Property="Cursor" Value="Arrow" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CanRenameChannel}" Value="True">
                                        <Setter Property="Cursor" Value="IBeam" />
                                        <Setter Property="ToolTip" Value="Edit channel name" />
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <TextBox x:Name="RenameTextBox"
                         Text="{Binding PendingName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InlineRenameTextBox}"
                         HorizontalAlignment="Center"
                         Visibility="{Binding IsRenaming, Converter={StaticResource BoolToVis}}"
                         TextChanged="RenameTextBox_TextChanged"
                         PreviewKeyDown="RenameTextBox_PreviewKeyDown"
                         LostFocus="RenameTextBox_LostFocus" />
            </Grid>

            <!-- Middle: Slider & VU Meter -->
            <Grid Grid.Row="1" Margin="0,8,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Slider Grid.Column="1"
                        Style="{StaticResource Vm.VolumeSlider}"
                        Orientation="Vertical"
                        Minimum="0"
                        Maximum="1"
                        Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TickFrequency="0.05"
                        IsSnapToTickEnabled="False" />

                <!-- VU Meter -->
                <ProgressBar Grid.Column="2"
                             Style="{StaticResource Vm.VerticalProgressBar}"
                             Orientation="Vertical"
                             Minimum="0"
                             Maximum="1"
                             Value="{Binding DisplayPeakValue, Mode=OneWay}"
                             Width="14"
                             Margin="8,0,0,0"
                             HorizontalAlignment="Right" />
            </Grid>

            <!-- Bottom Footer -->
            <Grid Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="32" />
                    <RowDefinition Height="58" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding SpacedVolumePercent}"
                           FontSize="14"
                           FontStyle="Normal"
                           FontWeight="Normal"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource Vm.AccentBrush}"
                           Margin="0,0,0,12" />

                <ToggleButton Grid.Row="1"
                              IsChecked="{Binding IsMuted, Mode=TwoWay}"
                              Style="{StaticResource Vm.MuteToggle}"
                              Margin="0">
                    <TextBlock Text="M&#x2009;U&#x2009;T&#x2009;E" FontStyle="Normal" FontWeight="Normal" FontSize="12" />
                </ToggleButton>

                <Grid Grid.Row="2"
                      Width="112"
                      Height="58"
                      Margin="0,3,0,0"
                      Visibility="{Binding CanShowEqualizerPlaceholder, Converter={StaticResource BoolToVis}}">
                    <Button Style="{StaticResource Vm.MuteButton}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="-8,0,0,0">
                        <TextBlock Text="E&#x2009;Q" FontStyle="Normal" FontWeight="Normal" FontSize="12" />
                    </Button>
                </Grid>

                <!-- Assigned Process Icons -->
                <Grid Grid.Row="2"
                      Width="112"
                      Height="58"
                      Margin="0,3,0,0"
                      Visibility="{Binding CanShowAssignedApps, Converter={StaticResource BoolToVis}}">
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Margin="-13,0,0,0"
                                Visibility="{Binding HasNoAssignedApps, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="N&#x2009;o&#x2009; &#x2009;A&#x2009;p&#x2009;p&#x2009;s"
                                   Foreground="#A8A8A8"
                                   FontSize="10"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="A&#x2009;s&#x2009;s&#x2009;i&#x2009;g&#x2009;n&#x2009;e&#x2009;d"
                                   Foreground="#A8A8A8"
                                   FontSize="10"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Margin="0,2,0,0" />
                    </StackPanel>

                    <Grid Width="96"
                          Height="62"
                          Margin="-10,0,0,0"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Visibility="{Binding HasAssignedApps, Converter={StaticResource BoolToVis}}">
                        <ItemsControl ItemsSource="{Binding VisibleAssignedProcessIcons}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4" Rows="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding Icon}"
                                           Width="16"
                                           Height="16"
                                           Margin="2,2,2,3"
                                           ToolTip="{Binding ProcessName}"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ToggleButton x:Name="MoreAppsToggle"
                                      Style="{StaticResource AppMoreToggle}"
                                      Margin="0,4,0,0"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Bottom"
                                      Visibility="{Binding HasHiddenAssignedApps, Converter={StaticResource BoolToVis}}" />
                    </Grid>

                    <Popup PlacementTarget="{Binding ElementName=MoreAppsToggle}"
                           Placement="Right"
                           StaysOpen="False"
                           IsOpen="{Binding IsChecked, ElementName=MoreAppsToggle, Mode=TwoWay}"
                           AllowsTransparency="True">
                        <Border Background="{StaticResource Vm.PanelBrush}"
                                BorderBrush="{StaticResource Vm.AccentBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10">
                            <ItemsControl ItemsSource="{Binding HiddenAssignedProcessIcons}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" MaxWidth="132" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Image Source="{Binding Icon}"
                                               Width="22"
                                               Height="22"
                                               Margin="4"
                                               ToolTip="{Binding ProcessName}"
                                               RenderOptions.BitmapScalingMode="HighQuality" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Popup>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
