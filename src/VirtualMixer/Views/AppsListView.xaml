<UserControl x:Class="VirtualMixer.Views.AppsListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodels="clr-namespace:VirtualMixer.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:MainWindowViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             FontFamily="{StaticResource Vm.DisplayFont}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="True">
            <ItemsControl ItemsSource="{Binding ActiveAudioApps}"
                          HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"
                                   HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Vm.AppCard}" Width="260" Margin="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="True">
                                    <Image Source="{Binding Icon}"
                                           Width="40"
                                           Height="40"
                                           Margin="0,0,12,0"
                                           DockPanel.Dock="Left"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           SnapsToDevicePixels="True" />

                                    <TextBlock VerticalAlignment="Center"
                                               Text="{Binding DisplayNameTwoLines}"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               Foreground="{StaticResource Vm.TextBrush}"
                                               TextWrapping="NoWrap"
                                               LineHeight="16"
                                               LineStackingStrategy="BlockLineHeight"
                                               ToolTip="{Binding DisplayName}"
                                               SnapsToDevicePixels="True"
                                               UseLayoutRounding="True"
                                               TextOptions.TextFormattingMode="Display" />
                                </DockPanel>

                                <StackPanel Grid.Row="1" Margin="0,10,0,12">
                                    <ComboBox ItemsSource="{Binding DataContext.AssignableChannelOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              SelectedValue="{Binding AssignedChannelId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              SelectedValuePath="Id"
                                              DisplayMemberPath="NameSpaced"
                                              Style="{StaticResource Vm.ComboBox}"
                                              ItemContainerStyle="{StaticResource Vm.ComboBoxItem}"
                                              Visibility="Visible" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource Vm.ScrollBarVertical}" />
            </ScrollViewer.Resources>
        </ScrollViewer>

        <Button Grid.Row="1"
                Content="R&#x2009;e&#x2009;f&#x2009;r&#x2009;e&#x2009;s&#x2009;h&#x2009; &#x2009;A&#x2009;p&#x2009;p&#x2009;s"
                Command="{Binding DataContext.RefreshPlayingAudioCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Style="{StaticResource Vm.SmallButton}"
                HorizontalAlignment="Right"
                Height="32"
                Margin="0,14,0,0" />
    </Grid>
</UserControl>
