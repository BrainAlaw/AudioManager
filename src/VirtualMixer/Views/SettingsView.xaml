<UserControl x:Class="VirtualMixer.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodels="clr-namespace:VirtualMixer.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:MainWindowViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             FontFamily="{StaticResource Vm.DisplayFont}">
    
    <TabControl TabStripPlacement="Left" Background="Transparent" BorderThickness="0" Padding="0" Margin="16">
        <TabControl.Resources>
            <Style TargetType="TabItem">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource Vm.MutedTextBrush}" />
                <Setter Property="Padding" Value="16,12" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}" Margin="0,0,24,4">
                                <ContentPresenter ContentSource="Header" HorizontalAlignment="Left" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource Vm.SurfaceBrush}" />
                                    <Setter Property="Foreground" Value="{StaticResource Vm.TextBrush}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource Vm.Surface2Brush}" />
                                    <Setter Property="Foreground" Value="{StaticResource Vm.TextBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </TabControl.Resources>

        <TabItem Header="G&#x2009;e&#x2009;n&#x2009;e&#x2009;r&#x2009;a&#x2009;l">
            <Grid Margin="16,0,0,0" TextElement.FontSize="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource Vm.SettingsField}">
                            <DockPanel>
                                <TextBlock Text="M&#x2009;i&#x2009;n&#x2009;i&#x2009;m&#x2009;i&#x2009;z&#x2009;e&#x2009; &#x2009;t&#x2009;o&#x2009; &#x2009;s&#x2009;y&#x2009;s&#x2009;t&#x2009;e&#x2009;m&#x2009; &#x2009;t&#x2009;r&#x2009;a&#x2009;y" VerticalAlignment="Center" Foreground="{StaticResource Vm.TextBrush}" />
                                <CheckBox IsChecked="{Binding MinimizeToTray, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Command="{Binding ToggleMinimizeToTrayCommand}"
                                          Style="{StaticResource Vm.SettingsCheckBox}"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center" />
                            </DockPanel>
                        </Border>

                        <Border Style="{StaticResource Vm.SettingsField}">
                            <DockPanel>
                                <TextBlock Text="C&#x2009;l&#x2009;o&#x2009;s&#x2009;e&#x2009; &#x2009;t&#x2009;o&#x2009; &#x2009;s&#x2009;y&#x2009;s&#x2009;t&#x2009;e&#x2009;m&#x2009; &#x2009;t&#x2009;r&#x2009;a&#x2009;y" VerticalAlignment="Center" Foreground="{StaticResource Vm.TextBrush}" />
                                <CheckBox IsChecked="{Binding CloseToTray, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Command="{Binding ToggleCloseToTrayCommand}"
                                          Style="{StaticResource Vm.SettingsCheckBox}"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center" />
                            </DockPanel>
                        </Border>

                        <Border Style="{StaticResource Vm.SettingsField}">
                            <DockPanel>
                                <TextBlock Text="S&#x2009;t&#x2009;a&#x2009;r&#x2009;t&#x2009; &#x2009;i&#x2009;n&#x2009; &#x2009;t&#x2009;r&#x2009;a&#x2009;y&#x2009; &#x2009;o&#x2009;n&#x2009; &#x2009;s&#x2009;t&#x2009;a&#x2009;r&#x2009;t&#x2009;u&#x2009;p" VerticalAlignment="Center" Foreground="{StaticResource Vm.TextBrush}" />
                                <CheckBox IsChecked="{Binding StartInTray, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Command="{Binding ToggleStartInTrayCommand}"
                                          Style="{StaticResource Vm.SettingsCheckBox}"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center" />
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Button Grid.Row="1"
                        Content="R&#x2009;e&#x2009;s&#x2009;e&#x2009;t&#x2009; &#x2009;A&#x2009;s&#x2009;s&#x2009;i&#x2009;g&#x2009;n&#x2009;m&#x2009;e&#x2009;n&#x2009;t&#x2009;s"
                        Command="{Binding ResetAssignmentsCommand}"
                        Style="{StaticResource Vm.SmallButton}"
                        HorizontalAlignment="Right"
                        Height="32"
                        Margin="0,14,0,0" />
            </Grid>
        </TabItem>

        <TabItem Header="C&#x2009;o&#x2009;n&#x2009;t&#x2009;r&#x2009;o&#x2009;l&#x2009; &#x2009;B&#x2009;i&#x2009;n&#x2009;d&#x2009;s">
            <ItemsControl ItemsSource="{Binding MidiBindingRows}" Margin="16,8,0,8">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource Vm.SurfaceBrush}"
                                BorderBrush="{StaticResource Vm.BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14,10"
                                Margin="0,0,12,8">
                                <Grid>
                                    <StackPanel VerticalAlignment="Center">
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding SpacedChannelName}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource Vm.TextBrush}"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Column="1"
                                            Content="R&#x2009;e&#x2009;s&#x2009;e&#x2009;t&#x2009; &#x2009;B&#x2009;i&#x2009;n&#x2009;d&#x2009;s"
                                            Command="{Binding DataContext.ClearChannelBindingsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding ChannelId}"
                                            Style="{StaticResource Vm.SmallButton}"
                                            Height="24" Padding="6,0" FontSize="10" />
                                </Grid>

                                <Border Height="1" Background="{StaticResource Vm.BorderBrush}" Margin="0,0,0,6" />

                                <StackPanel>
                                    <StackPanel Margin="0,0,0,4">
                                        <Grid Margin="0,0,0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="V&#x2009;o&#x2009;l&#x2009;u&#x2009;m&#x2009;e"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource Vm.MutedTextBrush}"
                                                       FontSize="10" />
                                            <Button Grid.Column="1"
                                                    Command="{Binding DataContext.LearnVolumeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding ChannelId}"
                                                    Style="{StaticResource Vm.SmallButton}"
                                                    Height="24" Padding="8,0" MinWidth="80">
                                                <Grid>
                                                    <TextBlock Text="{Binding SpacedVolumeMidiText}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="10">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsLearningVolumeMidi}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="W&#x2009;A&#x2009;I&#x2009;T&#x2009;I&#x2009;N&#x2009;G&#x2009;..." VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource Vm.AccentBrush}" FontWeight="SemiBold" FontSize="10">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsLearningVolumeMidi}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <DataTrigger.EnterActions>
                                                                            <BeginStoryboard>
                                                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                                     From="1" To="0.62" Duration="0:0:0.55" />
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </DataTrigger.EnterActions>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Button>
                                        </Grid>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="M&#x2009;u&#x2009;t&#x2009;e"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource Vm.MutedTextBrush}"
                                                       FontSize="10" />
                                            <Button Grid.Column="1"
                                                    Command="{Binding DataContext.LearnMuteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding ChannelId}"
                                                    Style="{StaticResource Vm.SmallButton}"
                                                    Height="24" Padding="8,0" MinWidth="80">
                                                <Grid>
                                                    <TextBlock Text="{Binding SpacedMuteMidiText}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="10">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsLearningMuteMidi}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="W&#x2009;A&#x2009;I&#x2009;T&#x2009;I&#x2009;N&#x2009;G&#x2009;..." VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource Vm.AccentBrush}" FontWeight="SemiBold" FontSize="10">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsLearningMuteMidi}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <DataTrigger.EnterActions>
                                                                            <BeginStoryboard>
                                                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                                     From="1" To="0.62" Duration="0:0:0.55" />
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </DataTrigger.EnterActions>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Button>
                                        </Grid>
                                    </StackPanel>

                                    <Border Height="1" Background="{StaticResource Vm.BorderBrush}" Margin="0,0,0,4" />

                                    <StackPanel>

                                        <Grid Margin="0,0,0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="V&#x2009;o&#x2009;l&#x2009;u&#x2009;m&#x2009;e"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource Vm.MutedTextBrush}"
                                                       FontSize="10" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button Command="{Binding DataContext.LearnVolumeUpKeybindCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding ChannelId}"
                                                        Style="{StaticResource Vm.SmallButton}"
                                                        Height="24" Padding="6,0" MinWidth="80"
                                                        Margin="0,0,4,0">
                                                    <Grid>
                                                        <TextBlock Text="{Binding SpacedVolUpKeybindText}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="10">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsLearningVolUpKeybind}" Value="True">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Text="W&#x2009;A&#x2009;I&#x2009;T&#x2009;I&#x2009;N&#x2009;G&#x2009;..." VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource Vm.AccentBrush}" FontWeight="SemiBold" FontSize="10">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsLearningVolUpKeybind}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                            <DataTrigger.EnterActions>
                                                                                <BeginStoryboard>
                                                                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                                         From="1" To="0.62" Duration="0:0:0.55" />
                                                                                    </Storyboard>
                                                                                </BeginStoryboard>
                                                                            </DataTrigger.EnterActions>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </Button>
                                                <Button Command="{Binding DataContext.LearnVolumeDownKeybindCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding ChannelId}"
                                                        Style="{StaticResource Vm.SmallButton}"
                                                        Height="24" Padding="6,0" MinWidth="80">
                                                    <Grid>
                                                        <TextBlock Text="{Binding SpacedVolDownKeybindText}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="10">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsLearningVolDownKeybind}" Value="True">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Text="W&#x2009;A&#x2009;I&#x2009;T&#x2009;I&#x2009;N&#x2009;G&#x2009;..." VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource Vm.AccentBrush}" FontWeight="SemiBold" FontSize="10">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsLearningVolDownKeybind}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                            <DataTrigger.EnterActions>
                                                                                <BeginStoryboard>
                                                                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                                         From="1" To="0.62" Duration="0:0:0.55" />
                                                                                    </Storyboard>
                                                                                </BeginStoryboard>
                                                                            </DataTrigger.EnterActions>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </Button>
                                            </StackPanel>
                                        </Grid>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="M&#x2009;u&#x2009;t&#x2009;e"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource Vm.MutedTextBrush}"
                                                       FontSize="10" />
                                            <Button Grid.Column="1"
                                                    Command="{Binding DataContext.LearnMuteKeybindCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding ChannelId}"
                                                    Style="{StaticResource Vm.SmallButton}"
                                                    Height="24" Padding="8,0" MinWidth="80">
                                                <Grid>
                                                    <TextBlock Text="{Binding SpacedMuteKeybindText}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="10">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsLearningMuteKeybind}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="W&#x2009;A&#x2009;I&#x2009;T&#x2009;I&#x2009;N&#x2009;G&#x2009;..." VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource Vm.AccentBrush}" FontWeight="SemiBold" FontSize="10">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsLearningMuteKeybind}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <DataTrigger.EnterActions>
                                                                            <BeginStoryboard>
                                                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                                     From="1" To="0.62" Duration="0:0:0.55" />
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </DataTrigger.EnterActions>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Button>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                                </StackPanel>
                                </Grid>
                            </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </TabItem>
    </TabControl>
</UserControl>
