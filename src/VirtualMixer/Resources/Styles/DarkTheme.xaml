<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:VirtualMixer.Converters">
    <converters:ProgressHeightConverter x:Key="Vm.ProgressHeightConverter" />

    <!-- Modern Dark Theme Palette -->
    <Color x:Key="Vm.Background">#121212</Color>
    <Color x:Key="Vm.Panel">#1E1E1E</Color>
    <Color x:Key="Vm.Surface">#252525</Color>
    <Color x:Key="Vm.Surface2">#2D2D2D</Color>
    <Color x:Key="Vm.Border">#333333</Color>
    <Color x:Key="Vm.Text">#F0F0F0</Color>
    <Color x:Key="Vm.MutedText">#888888</Color>
    <Color x:Key="Vm.Accent">#E10600</Color>
    <Color x:Key="Vm.Warning">#FF3B30</Color>
    <Color x:Key="Vm.MeterTrack">#333333</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="Vm.BackgroundBrush" Color="{StaticResource Vm.Background}" />
    <SolidColorBrush x:Key="Vm.PanelBrush" Color="{StaticResource Vm.Panel}" />
    <SolidColorBrush x:Key="Vm.SurfaceBrush" Color="{StaticResource Vm.Surface}" />
    <SolidColorBrush x:Key="Vm.Surface2Brush" Color="{StaticResource Vm.Surface2}" />
    <SolidColorBrush x:Key="Vm.BorderBrush" Color="{StaticResource Vm.Border}" />
    <SolidColorBrush x:Key="Vm.TextBrush" Color="{StaticResource Vm.Text}" />
    <SolidColorBrush x:Key="Vm.MutedTextBrush" Color="{StaticResource Vm.MutedText}" />
    <SolidColorBrush x:Key="Vm.AccentBrush" Color="{StaticResource Vm.Accent}" />
    <SolidColorBrush x:Key="Vm.WarningBrush" Color="{StaticResource Vm.Warning}" />
    <SolidColorBrush x:Key="Vm.MeterTrackBrush" Color="{StaticResource Vm.MeterTrack}" />

    <!-- Control Styles -->
    <Style x:Key="Vm.ChannelStrip" TargetType="Border">
        <Setter Property="Margin" Value="6" />
        <Setter Property="Padding" Value="16,18" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="{StaticResource Vm.SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource Vm.BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2" Direction="270" Color="Black"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Top Navigation Button -->
    <Style x:Key="Vm.NavButton" TargetType="RadioButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource Vm.MutedTextBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Margin" Value="4,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Vm.TextBrush}" />
                            <Setter Property="Background" Value="{StaticResource Vm.SurfaceBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Vm.TextBrush}" />
                            <Setter Property="Background" Value="{StaticResource Vm.AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#B81410" />
                            <Setter TargetName="Chrome" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.96" ScaleY="0.96" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Vm.TitleButton" TargetType="Button">
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="52" />
        <Setter Property="Foreground" Value="{StaticResource Vm.MutedTextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#331B0000" />
                            <Setter Property="Foreground" Value="{StaticResource Vm.TextBrush}" />
                            <Setter Property="BorderBrush" Value="{StaticResource Vm.AccentBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Vm.SmallButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Vm.TextBrush}" />
        <Setter Property="Background" Value="{StaticResource Vm.SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource Vm.BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#331B0000" />
                            <Setter Property="BorderBrush" Value="{StaticResource Vm.AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{StaticResource Vm.AccentBrush}" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="BorderBrush" Value="{StaticResource Vm.AccentBrush}" />
                            <Setter TargetName="Chrome" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.96" ScaleY="0.96" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Vm.TextToggle" TargetType="ToggleButton">
        <Setter Property="MinWidth" Value="120" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Foreground" Value="{StaticResource Vm.TextBrush}" />
        <Setter Property="Background" Value="{StaticResource Vm.SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource Vm.BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource Vm.Surface2Brush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Background" Value="{StaticResource Vm.AccentBrush}" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="BorderBrush" Value="{StaticResource Vm.AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#B81410" />
                            <Setter TargetName="Chrome" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.96" ScaleY="0.96" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Connect / Disconnect Toggle Button -->
    <Style x:Key="Vm.ConnectToggle" TargetType="ToggleButton" BasedOn="{StaticResource Vm.TextToggle}">
        <Setter Property="Content" Value="Connect" />
        <Style.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Content" Value="Disconnect" />
                <Setter Property="Background" Value="{StaticResource Vm.Surface2Brush}" />
                <Setter Property="BorderBrush" Value="{StaticResource Vm.BorderBrush}" />
                <Setter Property="Foreground" Value="{StaticResource Vm.WarningBrush}" />
            </Trigger>
            <Trigger Property="IsChecked" Value="False">
                <Setter Property="Content" Value="Connect" />
                <Setter Property="Background" Value="{StaticResource Vm.AccentBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderBrush" Value="{StaticResource Vm.AccentBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Settings CheckBox -->
    <Style x:Key="Vm.SettingsCheckBox" TargetType="CheckBox">
        <Setter Property="Height" Value="32" />
        <Setter Property="Foreground" Value="{StaticResource Vm.TextBrush}" />
        <Setter Property="Background" Value="{StaticResource Vm.SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource Vm.BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Background="Transparent">
                        <Border x:Name="CheckMark"
                                Width="22"
                                Height="22"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <Path x:Name="CheckIcon"
                                  Data="M 4,10 L 8,14 L 15,5"
                                  Stroke="White"
                                  StrokeThickness="2.5"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Width="16"
                                  Height="16"
                                  Stretch="Uniform"
                                  Visibility="Hidden" />
                        </Border>
                        <ContentPresenter HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          Margin="32,0,0,0"
                                          RecognizesAccessKey="True" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CheckMark" Property="Background" Value="{StaticResource Vm.Surface2Brush}" />
                            <Setter TargetName="CheckMark" Property="BorderBrush" Value="{StaticResource Vm.AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckMark" Property="Background" Value="{StaticResource Vm.AccentBrush}" />
                            <Setter TargetName="CheckMark" Property="BorderBrush" Value="{StaticResource Vm.AccentBrush}" />
                            <Setter TargetName="CheckIcon" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="False">
                            <Setter TargetName="CheckIcon" Property="Visibility" Value="Hidden" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="CheckMark" Property="Background" Value="#B81410" />
                            <Setter TargetName="CheckMark" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.92" ScaleY="0.92" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Vm.ComboBox" TargetType="ComboBox">
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Foreground" Value="{StaticResource Vm.TextBrush}" />
        <Setter Property="Background" Value="{StaticResource Vm.SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource Vm.BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid SnapsToDevicePixels="True">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" />
                        <TextBlock x:Name="PlaceholderText"
                                   Margin="8,0,36,0"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"
                                   Foreground="#A8A8A8"
                                   FontStyle="Normal"
                                   Text="UNASSIGNED"
                                   IsHitTestVisible="False"
                                   Visibility="Collapsed" />
                        <ToggleButton x:Name="ToggleButton"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Focusable="False"
                                      ClickMode="Press"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Grid Background="Transparent">
                                        <Path HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              Margin="0,0,12,0"
                                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                              Data="M 0 0 L 5 5 L 10 0 Z" />
                                    </Grid>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          IsHitTestVisible="False" />
                        <Popup x:Name="Popup"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               Focusable="False"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               PopupAnimation="Fade">
                            <Border Margin="0,4,0,0"
                                    Background="{StaticResource Vm.PanelBrush}"
                                    BorderBrush="{StaticResource Vm.BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                <ScrollViewer MaxHeight="220"
                                              SnapsToDevicePixels="True">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#331B0000" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="#E10600" />
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#331B0000" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="#E10600" />
                        </Trigger>
                        <Trigger Property="SelectedItem" Value="{x:Null}">
                            <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Vm.ComboBoxItem" TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{StaticResource Vm.TextBrush}" />
        <Setter Property="Background" Value="{StaticResource Vm.PanelBrush}" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="ItemBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Margin="2">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="#331B0000" />
                            <Setter Property="Foreground" Value="{StaticResource Vm.TextBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource Vm.AccentBrush}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style x:Key="Vm.AppCard" TargetType="Border">
        <Setter Property="Margin" Value="6" />
        <Setter Property="Padding" Value="14" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="{StaticResource Vm.SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource Vm.BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="Vm.SettingsField" TargetType="Border">
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="BorderBrush" Value="{StaticResource Vm.BorderBrush}" />
        <Setter Property="Padding" Value="0,12" />
        <Setter Property="Margin" Value="0,4" />
    </Style>

    <!-- Vertical VU Meter ProgressBar -->
    <Style x:Key="Vm.VerticalProgressBar" TargetType="ProgressBar">
        <Setter Property="Foreground" Value="{StaticResource Vm.AccentBrush}" />
        <Setter Property="Background" Value="{StaticResource Vm.MeterTrackBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid Width="18" SnapsToDevicePixels="True">
                        <Border Width="4"
                                Background="{TemplateBinding Background}"
                                CornerRadius="2"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Stretch"
                                ClipToBounds="True" />
                        <Border Width="4"
                                Background="{TemplateBinding Foreground}"
                                CornerRadius="2"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom">
                            <Border.Height>
                                <MultiBinding Converter="{StaticResource Vm.ProgressHeightConverter}">
                                    <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="ActualHeight" />
                                    <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Value" />
                                </MultiBinding>
                            </Border.Height>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Vm.ScrollBarThumb" TargetType="{x:Type Thumb}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border Background="{StaticResource Vm.AccentBrush}"
                            CornerRadius="6"
                            BorderBrush="{StaticResource Vm.AccentBrush}"
                            BorderThickness="1" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Vm.ScrollBarTrack" TargetType="{x:Type RepeatButton}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Vm.ScrollBarVertical" TargetType="ScrollBar">
        <Setter Property="Width" Value="10" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource Vm.AccentBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Width="{TemplateBinding Width}" Background="Transparent" SnapsToDevicePixels="True">
                        <Track x:Name="PART_Track"
                               Orientation="Vertical"
                               IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource Vm.ScrollBarTrack}" />
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource Vm.ScrollBarThumb}" Height="48" Width="10" />
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource Vm.ScrollBarTrack}" />
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Mute ToggleButton -->
    <Style x:Key="Vm.MuteButton" TargetType="Button">
        <Setter Property="Width" Value="82" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Foreground" Value="{StaticResource Vm.TextBrush}" />
        <Setter Property="Background" Value="{StaticResource Vm.Surface2Brush}" />
        <Setter Property="BorderBrush" Value="{StaticResource Vm.BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#331B0000" />
                            <Setter Property="BorderBrush" Value="{StaticResource Vm.AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#B81410" />
                            <Setter TargetName="Chrome" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.96" ScaleY="0.96" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Vm.MuteToggle" TargetType="ToggleButton">
        <Setter Property="Width" Value="82" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Foreground" Value="{StaticResource Vm.TextBrush}" />
        <Setter Property="Background" Value="{StaticResource Vm.Surface2Brush}" />
        <Setter Property="BorderBrush" Value="{StaticResource Vm.BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#331B0000" />
                            <Setter Property="BorderBrush" Value="{StaticResource Vm.AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Background" Value="{StaticResource Vm.AccentBrush}" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="BorderBrush" Value="{StaticResource Vm.AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#B81410" />
                            <Setter TargetName="Chrome" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.96" ScaleY="0.96" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Vertical Volume Slider -->
    <Style x:Key="Vm.SliderThumb" TargetType="{x:Type Thumb}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border Background="{StaticResource Vm.TextBrush}"
                            CornerRadius="9"
                            BorderBrush="{StaticResource Vm.AccentBrush}"
                            BorderThickness="1"
                            Width="18" Height="18">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="6" Opacity="0.24" ShadowDepth="0" Color="#E10600" />
                        </Border.Effect>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Vm.SliderDecreaseButton" TargetType="{x:Type RepeatButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border Background="{TemplateBinding Background}" CornerRadius="0,0,2,2" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Vm.SliderIncreaseButton" TargetType="{x:Type RepeatButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border Background="{TemplateBinding Background}" CornerRadius="2,2,0,0" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Vm.VolumeSlider" TargetType="Slider">
        <Setter Property="Background" Value="{StaticResource Vm.MeterTrackBrush}" />
        <Setter Property="Foreground" Value="{StaticResource Vm.AccentBrush}" />
        <Setter Property="Width" Value="18" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid Width="18" SnapsToDevicePixels="True">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2" Width="4" HorizontalAlignment="Center" />
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="{x:Static Slider.DecreaseLarge}" 
                                              Style="{StaticResource Vm.SliderDecreaseButton}"
                                              Background="{TemplateBinding Foreground}"
                                              Width="4"
                                              HorizontalAlignment="Center" />
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="{x:Static Slider.IncreaseLarge}" 
                                              Style="{StaticResource Vm.SliderIncreaseButton}"
                                              Background="Transparent"
                                              Width="4"
                                              HorizontalAlignment="Center" />
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource Vm.SliderThumb}" />
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Vm.DataGridColumnHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Foreground" Value="{StaticResource Vm.MutedTextBrush}" />
        <Setter Property="Background" Value="{StaticResource Vm.PanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource Vm.BorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="8,12" />
    </Style>

    <Style x:Key="Vm.DataGridCell" TargetType="DataGridCell">
        <Setter Property="Foreground" Value="{StaticResource Vm.TextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{StaticResource Vm.BorderBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8" />
    </Style>

    <Style x:Key="Vm.OsdProgressBar" TargetType="ProgressBar">
        <Setter Property="Foreground" Value="{StaticResource Vm.AccentBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- Horizontal Peak Progress Bar for App Cards -->
    <Style x:Key="Vm.PeakProgressBar" TargetType="ProgressBar">
        <Setter Property="Foreground" Value="{StaticResource Vm.AccentBrush}" />
        <Setter Property="Background" Value="{StaticResource Vm.MeterTrackBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="MinHeight" Value="4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border Background="{TemplateBinding Background}" CornerRadius="2" ClipToBounds="True">
                        <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" HorizontalAlignment="Left" CornerRadius="2" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
